" ========================================
" Lazy-idea: LazyVim Keybindings for JetBrains IDEs
" ========================================
" https://github.com/cufarvid/lazy-idea
"
" This configuration replicates LazyVim keybindings in JetBrains IDEs
" through IdeaVim, making it feel like home for LazyVim users.
"
" Installation:
"   git clone https://github.com/cufarvid/lazy-idea.git ~/.lazy-idea
"
" To track Action-IDs:
"   :action VimFindActionIdAction

" ========================================
" Load Configuration Modules
" ========================================

" Core settings (leader keys, visual settings, Neovim compatibility)
source ~/.lazy-idea/lazy-idea/settings.vim

" Plugin configurations (commentary, surround, easymotion, which-key, text objects)
source ~/.lazy-idea/lazy-idea/plugins.vim

" Editor keymaps (windows, buffers, UI, terminal, notifications)
source ~/.lazy-idea/lazy-idea/editor.vim

" Code/LSP keymaps (navigation, refactoring, actions)
source ~/.lazy-idea/lazy-idea/code.vim

" Git operations
source ~/.lazy-idea/lazy-idea/git.vim

" Search/Find operations (Telescope-like, Todo comments)
source ~/.lazy-idea/lazy-idea/search.vim

" Debug (DAP) keymaps
source ~/.lazy-idea/lazy-idea/debug.vim

" Test framework integration
source ~/.lazy-idea/lazy-idea/test.vim

" Neovim defaults and smart selection
source ~/.lazy-idea/lazy-idea/defaults.vim
